# =============================================================================
# JBAC Strategy Foundry - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git - it's in .gitignore for security
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram Bot Configuration (Centralized)
# -----------------------------------------------------------------------------
# Team-wide Telegram bot for trading alerts
# Setup Instructions:
#   1. Message @BotFather on Telegram
#   2. Send /newbot command
#   3. Choose name: "JBAC Strategy Alerts" (or similar)
#   4. Get bot token (looks like: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz)
#   5. Share bot with team members
#   6. Each member messages @userinfobot to get their chat_id
#
# For production deployment, use your actual bot token:
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Individual chat IDs (comma-separated for multiple recipients)
# Get yours by messaging @userinfobot on Telegram
# Format: 123456789,987654321,555555555
TELEGRAM_CHAT_IDS=your_chat_id_here

# Optional: Telegram channel for team-wide alerts
# Format: -100123456789 (channels have negative IDs)
TELEGRAM_CHANNEL_ID=

# -----------------------------------------------------------------------------
# Broker API Keys (Optional - for live trading)
# -----------------------------------------------------------------------------
# Alpaca API credentials
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # paper trading by default

# Interactive Brokers
IB_HOST=127.0.0.1
IB_PORT=7497  # 7497 for TWS paper, 7496 for TWS live
IB_CLIENT_ID=1

# -----------------------------------------------------------------------------
# Data Sources (Optional)
# -----------------------------------------------------------------------------
# Alpha Vantage API key for market data
ALPHA_VANTAGE_API_KEY=

# Yahoo Finance (no API key needed, but rate limited)
USE_YFINANCE=true

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Environment: development, staging, production
APP_ENV=development

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable/disable specific alert channels
ENABLE_TELEGRAM_ALERTS=true
ENABLE_CONSOLE_ALERTS=true
ENABLE_EMAIL_ALERTS=false

# Minimum alert severity: INFO, WARNING, ERROR, CRITICAL
MIN_ALERT_SEVERITY=INFO
