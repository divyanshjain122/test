# =============================================================================
# JBAC Strategy Foundry - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git - it's in .gitignore for security
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram Bot Configuration (Your Personal Bot)
# -----------------------------------------------------------------------------
# Configure YOUR OWN bot for private paper trading alerts
# 
# 🚀 QUICK SETUP (2 minutes):
#   Run: python -m jsf.cli.setup_telegram
#   
# 📖 MANUAL SETUP:
#   1. Message @BotFather on Telegram → Send /newbot
#   2. Choose name: "My Trading Alerts" (or anything you like)
#   3. Get bot token (looks like: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz)
#   4. Message @userinfobot → Get your chat_id (e.g., 987654321)
#   5. Search for your bot → Click "START"
#   6. Paste values below
#
# ⚠️  SECURITY:
#   - Keep your token SECRET (don't share publicly)
#   - This file (.env) is in .gitignore - safe from git
#   - Use PAPER TRADING credentials only (not live broker keys)
#
# 📊 PAPER TRADING ALERTS:
#   - Perfect for learning and testing strategies
#   - No real money at risk
#   - Receive alerts on: signals, trades, risk warnings
#
# Your bot token (from @BotFather):
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your chat ID (from @userinfobot):
TELEGRAM_CHAT_IDS=your_chat_id_here

# Optional: Telegram channel for team-wide alerts
# Format: -100123456789 (channels have negative IDs)
TELEGRAM_CHANNEL_ID=

# -----------------------------------------------------------------------------
# Broker API Keys (Optional - for live trading)
# -----------------------------------------------------------------------------
# Alpaca API credentials
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # paper trading by default

# Interactive Brokers
IB_HOST=127.0.0.1
IB_PORT=7497  # 7497 for TWS paper, 7496 for TWS live
IB_CLIENT_ID=1

# -----------------------------------------------------------------------------
# Data Sources (Optional)
# -----------------------------------------------------------------------------
# Alpha Vantage API key for market data
ALPHA_VANTAGE_API_KEY=

# Yahoo Finance (no API key needed, but rate limited)
USE_YFINANCE=true

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Environment: development, staging, production
APP_ENV=development

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable/disable specific alert channels
ENABLE_TELEGRAM_ALERTS=true
ENABLE_CONSOLE_ALERTS=true
ENABLE_EMAIL_ALERTS=false

# Minimum alert severity: INFO, WARNING, ERROR, CRITICAL
MIN_ALERT_SEVERITY=INFO
